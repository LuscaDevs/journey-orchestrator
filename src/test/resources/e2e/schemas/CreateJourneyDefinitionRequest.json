{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CreateJourneyDefinitionRequest",
  "type": "object",
  "required": ["journeyCode", "name", "version", "states", "transitions"],
  "properties": {
    "journeyCode": { "type": "string" },
    "name": { "type": "string" },
    "version": { "type": "integer" },
    "states": {
      "type": "array",
      "items": { "$ref": "#/definitions/State" }
    },
    "transitions": {
      "type": "array",
      "items": { "$ref": "#/definitions/TransitionRequest" }
    }
  },
  "definitions": {
    "State": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string" },
        "type": { "$ref": "#/definitions/StateType" }
      }
    },
    "StateType": {
      "type": "string",
      "enum": ["INITIAL", "INTERMEDIATE", "FINAL"]
    },
    "TransitionRequest": {
      "type": "object",
      "required": ["source", "event", "target"],
      "properties": {
        "source": { "type": "string" },
        "event": { "type": "string" },
        "target": { "type": "string" },
        "condition": { "type": "string" }
      }
    }
  }
}
