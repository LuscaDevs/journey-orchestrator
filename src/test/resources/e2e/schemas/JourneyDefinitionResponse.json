{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "JourneyDefinitionResponse",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "journeyCode": { "type": "string" },
    "name": { "type": "string" },
    "version": { "type": "integer" },
    "states": {
      "type": "array",
      "items": { "$ref": "#/definitions/State" }
    },
    "transitions": {
      "type": "array",
      "items": { "$ref": "#/definitions/TransitionResponse" }
    },
    "status": { "type": "string", "enum": ["ATIVA", "INATIVA", "RASCUNHO"] },
    "createdAt": { "type": "string", "format": "date-time" }
  },
  "definitions": {
    "State": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string" },
        "type": { "$ref": "#/definitions/StateType" }
      }
    },
    "StateType": {
      "type": "string",
      "enum": ["INITIAL", "INTERMEDIATE", "FINAL"]
    },
    "TransitionResponse": {
      "type": "object",
      "properties": {
        "source": { "type": "string" },
        "event": { "type": "string" },
        "target": { "type": "string" },
        "condition": { "type": "string" }
      }
    }
  }
}
