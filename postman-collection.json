	"item": [
		{
			"name": "Journey Definitions",
			"item": [
				{
					"name": "Create Journey Definition",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test(\"Response has journey definition data\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('journeyCode');",
									"    pm.expect(jsonData).to.have.property('name');",
									"    pm.expect(jsonData).to.have.property('version');",
									"    pm.expect(jsonData).to.have.property('states');",
									"    pm.expect(jsonData).to.have.property('transitions');",
									"});",
									"",
									"// Salvar journeyCode para usar em outras requisições",
									"if (pm.response.code === 201) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('journeyCode', jsonData.journeyCode);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"journeyCode\": \"loan-approval\",\n  \"name\": \"Loan Approval Journey with Conditions\",\n  \"version\": 1,\n  \"states\": [\n    {\n      \"name\": \"START\",\n      \"type\": \"INITIAL\"\n    },\n    {\n      \"name\": \"DOCUMENTS_PENDING\",\n      \"type\": \"INTERMEDIATE\"\n    },\n    {\n      \"name\": \"DOCUMENTS_VERIFIED\",\n      \"type\": \"INTERMEDIATE\"\n    },\n    {\n      \"name\": \"MANUAL_REVIEW\",\n      \"type\": \"INTERMEDIATE\"\n    },\n    {\n      \"name\": \"APPROVED\",\n      \"type\": \"INTERMEDIATE\"\n    },\n    {\n      \"name\": \"REJECTED\",\n      \"type\": \"INTERMEDIATE\"\n    },\n    {\n      \"name\": \"COMPLETED\",\n      \"type\": \"FINAL\"\n    }\n  ],\n  \"transitions\": [\n    {\n      \"source\": \"START\",\n      \"event\": \"SUBMIT_APPLICATION\",\n      \"target\": \"DOCUMENTS_PENDING\"\n    },\n    {\n      \"source\": \"DOCUMENTS_PENDING\",\n      \"event\": \"UPLOAD_DOCUMENTS\",\n      \"target\": \"DOCUMENTS_VERIFIED\"\n    },\n    {\n      \"source\": \"DOCUMENTS_VERIFIED\",\n      \"event\": \"EVALUATE_RISK\",\n      \"target\": \"APPROVED\",\n      \"condition\": \"#eventData.riskScore <= 50 AND #eventData.income > 3000\"\n    },\n    {\n      \"source\": \"DOCUMENTS_VERIFIED\",\n      \"event\": \"EVALUATE_RISK\",\n      \"target\": \"MANUAL_REVIEW\",\n      \"condition\": \"#eventData.riskScore > 50 AND #eventData.riskScore <= 80\"\n    },\n    {\n      \"source\": \"DOCUMENTS_VERIFIED\",\n      \"event\": \"EVALUATE_RISK\",\n      \"target\": \"REJECTED\",\n      \"condition\": \"#eventData.riskScore > 80 OR #eventData.income <= 3000\"\n    },\n    {\n      \"source\": \"MANUAL_REVIEW\",\n      \"event\": \"MANUAL_APPROVAL\",\n      \"target\": \"APPROVED\"\n    },\n    {\n      \"source\": \"MANUAL_REVIEW\",\n      \"event\": \"MANUAL_REJECTION\",\n      \"target\": \"REJECTED\"\n    },\n    {\n      \"source\": \"APPROVED\",\n      \"event\": \"DISBURSE_LOAN\",\n      \"target\": \"COMPLETED\"\n    },\n    {\n      \"source\": \"REJECTED\",\n      \"event\": \"NOTIFY_REJECTION\",\n      \"target\": \"COMPLETED\"\n    }\n  ]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/journeys",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"journeys"
							]
						}
					},
					"response": []
				},
				{
					"name": "List All Journey Definitions",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response is an array\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.be.an('array');",
									"});",
									"",
									"pm.test(\"Each journey definition has required fields\", function () {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.length > 0) {",
									"        jsonData.forEach(function(journey) {",
									"            pm.expect(journey).to.have.property('journeyCode');",
									"            pm.expect(journey).to.have.property('name');",
									"            pm.expect(journey).to.have.property('version');",
									"        });",
									"    }",
									"});"
								],
